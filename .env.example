# === Required ===
YEARLY_KWH=4000
ADDRESS_LABEL=Din adresse, postnr by
PRICE_AREA=DK1  # DK1 (Vestdanmark) or DK2 (Østdanmark)

# === Optional: Min Strøm API (https://docs.minstroem.app) ===
# Gives full prices incl. tariffs for your exact address
# Request access: engberg@minstroem.app
MINSTROEM_API_KEY=
MINSTROEM_API_SECRET=
MINSTROEM_ADDRESS_ID=

# === Optional: Eloverblik (https://eloverblik.dk) ===
# Shows your actual consumption data
ELOVERBLIK_TOKEN=
METERING_POINTS=  # comma-separated metering point IDs
